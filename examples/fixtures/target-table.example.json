{
  "id": "t_target",
  "fields": [
    {
      "id": "f_company_target",
      "name": "Company",
      "type": "text"
    },
    {
      "id": "f_domain_target",
      "name": "Domain",
      "type": "formula",
      "typeSettings": {
        "formulaText": "{{f_company_target}}?.toLowerCase()?.replaceAll(' ', '') + '.com'"
      },
      "inputFieldIds": ["f_company_target"]
    },
    {
      "id": "f_http_target",
      "name": "Lookup Company",
      "type": "action",
      "typeSettings": {
        "actionKey": "http-api-v2",
        "actionPackageId": "4299091f-3cd3-4d68-b198-0143575f471d",
        "actionVersion": 1,
        "inputsBinding": [
          {
            "name": "method",
            "formulaText": "\"GET\""
          },
          {
            "name": "endpoint",
            "formulaText": "\"https://example.invalid/company?domain=\" + encodeURIComponent({{f_domain_target}})"
          }
        ]
      },
      "inputFieldIds": ["f_domain_target"],
      "conditionalRunFormulaText": "!!{{f_domain_target}}"
    }
  ],
  "views": [
    {
      "id": "gv_target",
      "name": "Default View",
      "fields": {
        "f_company_target": {
          "isVisible": true,
          "order": 0
        },
        "f_domain_target": {
          "isVisible": true,
          "order": 1
        },
        "f_http_target": {
          "isVisible": false,
          "order": 2
        }
      }
    }
  ]
}
